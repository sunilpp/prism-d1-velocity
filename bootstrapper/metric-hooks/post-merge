#!/usr/bin/env bash
# post-merge — Emit prism.d1.pr event with merge metrics.
#
# This hook runs after a successful git merge (including git pull).
# It calculates the time from first commit in the merged branch to the merge
# and emits a prism.d1.pr event.
#
# Installation: metric-hooks/install.sh

# Do not use set -e — this hook must never block a merge
set -uo pipefail

# ---------------------------------------------------------------------------
# Load configuration
# ---------------------------------------------------------------------------
CONFIG_FILE=".prism/config.json"
TEAM_ID="unknown"
REPO="unknown"
EVENT_BUS="prism-d1-metrics"
AWS_REGION="us-west-2"
EMIT_TO_EB="true"
STORE_LOCAL="true"
PRISM_LEVEL=2

if [[ -f "${CONFIG_FILE}" ]]; then
    TEAM_ID=$(jq -r '.team_id // "unknown"' "${CONFIG_FILE}" 2>/dev/null || echo "unknown")
    REPO=$(jq -r '.repo // "unknown"' "${CONFIG_FILE}" 2>/dev/null || echo "unknown")
    EVENT_BUS=$(jq -r '.event_bus // "prism-d1-metrics"' "${CONFIG_FILE}" 2>/dev/null || echo "prism-d1-metrics")
    AWS_REGION=$(jq -r '.aws_region // "us-west-2"' "${CONFIG_FILE}" 2>/dev/null || echo "us-west-2")
    EMIT_TO_EB=$(jq -r '.emit_to_eventbridge // true' "${CONFIG_FILE}" 2>/dev/null || echo "true")
    STORE_LOCAL=$(jq -r '.store_local // true' "${CONFIG_FILE}" 2>/dev/null || echo "true")
    PRISM_LEVEL=$(jq -r '.prism_level // 2' "${CONFIG_FILE}" 2>/dev/null || echo "2")
fi

# ---------------------------------------------------------------------------
# Calculate merge metrics
# ---------------------------------------------------------------------------
MERGE_SHA=$(git rev-parse HEAD 2>/dev/null || echo "unknown")
TIMESTAMP=$(date -u +"%Y-%m-%dT%H:%M:%SZ")
MERGE_TS=$(date +%s)

# Get the merge parents
PARENTS=$(git log -1 --format='%P' 2>/dev/null || echo "")
PARENT_COUNT=$(echo "${PARENTS}" | wc -w | tr -d ' ')

# If this is a merge commit (2 parents), calculate time from branch point
FIRST_COMMIT_TS="${MERGE_TS}"
COMMIT_COUNT=0
AI_COMMIT_COUNT=0

if [[ "${PARENT_COUNT}" -ge 2 ]]; then
    MAIN_PARENT=$(echo "${PARENTS}" | awk '{print $1}')
    BRANCH_PARENT=$(echo "${PARENTS}" | awk '{print $2}')

    # Find the merge base
    MERGE_BASE=$(git merge-base "${MAIN_PARENT}" "${BRANCH_PARENT}" 2>/dev/null || echo "")

    if [[ -n "${MERGE_BASE}" ]]; then
        # First commit timestamp on the branch
        FIRST_COMMIT_TS=$(git log "${MERGE_BASE}..${BRANCH_PARENT}" --format='%ct' --reverse 2>/dev/null | head -1 || echo "${MERGE_TS}")
        COMMIT_COUNT=$(git rev-list --count "${MERGE_BASE}..${BRANCH_PARENT}" 2>/dev/null || echo "0")

        # Count AI commits in the branch
        BRANCH_MESSAGES=$(git log "${MERGE_BASE}..${BRANCH_PARENT}" --format='%B' 2>/dev/null || echo "")
        AI_COMMIT_COUNT=$(echo "${BRANCH_MESSAGES}" | grep -c '^AI-Origin: ai-\(generated\|assisted\)' || true)
    fi
fi

# Calculate merge lead time
if [[ "${FIRST_COMMIT_TS}" =~ ^[0-9]+$ ]]; then
    MERGE_LEAD_TIME_SECONDS=$((MERGE_TS - FIRST_COMMIT_TS))
    MERGE_LEAD_TIME_HOURS=$(echo "scale=2; ${MERGE_LEAD_TIME_SECONDS} / 3600" | bc -l 2>/dev/null || echo "0")
else
    MERGE_LEAD_TIME_SECONDS=0
    MERGE_LEAD_TIME_HOURS="0"
fi

# AI-to-merge ratio
if [[ "${COMMIT_COUNT}" -gt 0 ]]; then
    AI_RATIO=$(echo "scale=4; ${AI_COMMIT_COUNT} / ${COMMIT_COUNT}" | bc -l 2>/dev/null || echo "0")
else
    AI_RATIO="0"
fi

# ---------------------------------------------------------------------------
# Build metric payload
# ---------------------------------------------------------------------------
METRIC_JSON=$(jq -n \
    --arg team_id "${TEAM_ID}" \
    --arg repo "${REPO}" \
    --arg timestamp "${TIMESTAMP}" \
    --arg prism_level "${PRISM_LEVEL}" \
    --arg merge_sha "${MERGE_SHA}" \
    --argjson commit_count "${COMMIT_COUNT}" \
    --argjson ai_commit_count "${AI_COMMIT_COUNT}" \
    --argjson ai_ratio "${AI_RATIO}" \
    --argjson lead_time_seconds "${MERGE_LEAD_TIME_SECONDS}" \
    --argjson lead_time_hours "${MERGE_LEAD_TIME_HOURS}" \
    '{
        "team_id": $team_id,
        "repo": $repo,
        "timestamp": $timestamp,
        "prism_level": ($prism_level | tonumber),
        "metric": {
            "name": "merge",
            "value": 1,
            "unit": "count"
        },
        "ai_context": {
            "tool": "git",
            "model": "n/a",
            "origin": "human"
        },
        "dora": {
            "lead_time_seconds": $lead_time_seconds,
            "lead_time_hours": $lead_time_hours
        },
        "ai_dora": {
            "ai_to_merge_ratio": $ai_ratio,
            "total_commits": $commit_count,
            "ai_commits": $ai_commit_count
        },
        "merge": {
            "sha": $merge_sha,
            "commits_merged": $commit_count
        }
    }' 2>/dev/null || echo "{}")

# ---------------------------------------------------------------------------
# Store locally
# ---------------------------------------------------------------------------
if [[ "${STORE_LOCAL}" == "true" ]]; then
    METRICS_DIR=".prism/metrics"
    mkdir -p "${METRICS_DIR}" 2>/dev/null || true
    METRIC_FILE="${METRICS_DIR}/merge-$(date +%s)-$$.json"
    echo "${METRIC_JSON}" > "${METRIC_FILE}" 2>/dev/null || true
fi

# ---------------------------------------------------------------------------
# Emit to EventBridge (async, non-blocking)
# ---------------------------------------------------------------------------
if [[ "${EMIT_TO_EB}" == "true" ]]; then
    if command -v aws &>/dev/null; then
        (
            aws events put-events \
                --region "${AWS_REGION}" \
                --entries "[{
                    \"Source\": \"prism.d1.velocity\",
                    \"DetailType\": \"prism.d1.pr\",
                    \"EventBusName\": \"${EVENT_BUS}\",
                    \"Detail\": $(echo "${METRIC_JSON}" | jq -c '.' | jq -Rs '.')
                }]" > /dev/null 2>&1
        ) &
    fi
fi

exit 0
