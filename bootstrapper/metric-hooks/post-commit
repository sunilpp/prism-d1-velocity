#!/usr/bin/env bash
# post-commit — Emit prism.d1.commit event and store local metrics.
#
# This hook reads the commit trailers, calculates diff stats, and:
#   1. Emits a prism.d1.commit event to EventBridge (async, non-blocking)
#   2. Stores the metric locally in .prism/metrics/ as JSON
#
# Installation: metric-hooks/install.sh

# Do not use set -e — this hook must never block a commit
set -uo pipefail

# ---------------------------------------------------------------------------
# Load configuration
# ---------------------------------------------------------------------------
CONFIG_FILE=".prism/config.json"
TEAM_ID="unknown"
REPO="unknown"
EVENT_BUS="prism-d1-metrics"
AWS_REGION="us-west-2"
EMIT_TO_EB="true"
STORE_LOCAL="true"
PRISM_LEVEL=2

if [[ -f "${CONFIG_FILE}" ]]; then
    TEAM_ID=$(jq -r '.team_id // "unknown"' "${CONFIG_FILE}" 2>/dev/null || echo "unknown")
    REPO=$(jq -r '.repo // "unknown"' "${CONFIG_FILE}" 2>/dev/null || echo "unknown")
    EVENT_BUS=$(jq -r '.event_bus // "prism-d1-metrics"' "${CONFIG_FILE}" 2>/dev/null || echo "prism-d1-metrics")
    AWS_REGION=$(jq -r '.aws_region // "us-west-2"' "${CONFIG_FILE}" 2>/dev/null || echo "us-west-2")
    EMIT_TO_EB=$(jq -r '.emit_to_eventbridge // true' "${CONFIG_FILE}" 2>/dev/null || echo "true")
    STORE_LOCAL=$(jq -r '.store_local // true' "${CONFIG_FILE}" 2>/dev/null || echo "true")
    PRISM_LEVEL=$(jq -r '.prism_level // 2' "${CONFIG_FILE}" 2>/dev/null || echo "2")
fi

# ---------------------------------------------------------------------------
# Read commit metadata
# ---------------------------------------------------------------------------
COMMIT_SHA=$(git rev-parse HEAD 2>/dev/null || echo "unknown")
COMMIT_MSG=$(git log -1 --format='%B' 2>/dev/null || echo "")
TIMESTAMP=$(date -u +"%Y-%m-%dT%H:%M:%SZ")
AUTHOR=$(git log -1 --format='%ae' 2>/dev/null || echo "unknown")

# Read trailers
AI_ORIGIN=$(echo "${COMMIT_MSG}" | grep '^AI-Origin:' | head -1 | sed 's/^AI-Origin: *//' || echo "unknown")
AI_TOOL=$(echo "${COMMIT_MSG}" | grep '^AI-Tool:' | head -1 | sed 's/^AI-Tool: *//' || echo "")
AI_MODEL=$(echo "${COMMIT_MSG}" | grep '^AI-Model:' | head -1 | sed 's/^AI-Model: *//' || echo "")
SPEC_REF=$(echo "${COMMIT_MSG}" | grep '^Spec-Ref:' | head -1 | sed 's/^Spec-Ref: *//' || echo "")

# Diff stats
DIFF_STAT=$(git diff --shortstat HEAD~1 HEAD 2>/dev/null || echo "")
FILES_CHANGED=$(echo "${DIFF_STAT}" | grep -oP '\d+(?= file)' || echo "0")
LINES_ADDED=$(echo "${DIFF_STAT}" | grep -oP '\d+(?= insertion)' || echo "0")
LINES_REMOVED=$(echo "${DIFF_STAT}" | grep -oP '\d+(?= deletion)' || echo "0")

# ---------------------------------------------------------------------------
# Build metric payload
# ---------------------------------------------------------------------------
METRIC_JSON=$(jq -n \
    --arg team_id "${TEAM_ID}" \
    --arg repo "${REPO}" \
    --arg timestamp "${TIMESTAMP}" \
    --arg prism_level "${PRISM_LEVEL}" \
    --arg commit_sha "${COMMIT_SHA}" \
    --arg author "${AUTHOR}" \
    --arg ai_origin "${AI_ORIGIN}" \
    --arg ai_tool "${AI_TOOL}" \
    --arg ai_model "${AI_MODEL}" \
    --arg spec_ref "${SPEC_REF}" \
    --arg files_changed "${FILES_CHANGED}" \
    --arg lines_added "${LINES_ADDED}" \
    --arg lines_removed "${LINES_REMOVED}" \
    '{
        "team_id": $team_id,
        "repo": $repo,
        "timestamp": $timestamp,
        "prism_level": ($prism_level | tonumber),
        "metric": {
            "name": "commit",
            "value": 1,
            "unit": "count"
        },
        "ai_context": {
            "tool": (if $ai_tool == "" then "none" else $ai_tool end),
            "model": (if $ai_model == "" then "n/a" else $ai_model end),
            "origin": $ai_origin
        },
        "commit": {
            "sha": $commit_sha,
            "author": $author,
            "spec_ref": $spec_ref,
            "files_changed": ($files_changed | tonumber),
            "lines_added": ($lines_added | tonumber),
            "lines_removed": ($lines_removed | tonumber)
        }
    }' 2>/dev/null || echo "{}")

# ---------------------------------------------------------------------------
# Store locally
# ---------------------------------------------------------------------------
if [[ "${STORE_LOCAL}" == "true" ]]; then
    METRICS_DIR=".prism/metrics"
    mkdir -p "${METRICS_DIR}" 2>/dev/null || true
    METRIC_FILE="${METRICS_DIR}/commit-$(date +%s)-$$.json"
    echo "${METRIC_JSON}" > "${METRIC_FILE}" 2>/dev/null || true
fi

# ---------------------------------------------------------------------------
# Emit to EventBridge (async, non-blocking)
# ---------------------------------------------------------------------------
if [[ "${EMIT_TO_EB}" == "true" ]]; then
    if command -v aws &>/dev/null; then
        (
            aws events put-events \
                --region "${AWS_REGION}" \
                --entries "[{
                    \"Source\": \"prism.d1.velocity\",
                    \"DetailType\": \"prism.d1.commit\",
                    \"EventBusName\": \"${EVENT_BUS}\",
                    \"Detail\": $(echo "${METRIC_JSON}" | jq -c '.' | jq -Rs '.')
                }]" > /dev/null 2>&1
        ) &
    fi
fi

exit 0
