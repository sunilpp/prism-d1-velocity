{
  "widgets": [
    {
      "type": "text",
      "x": 0,
      "y": 0,
      "width": 24,
      "height": 1,
      "properties": {
        "markdown": "# PRISM D1 Velocity — Executive Readout\nLeadership view of engineering AI adoption and delivery performance"
      }
    },

    {
      "type": "metric",
      "x": 0,
      "y": 1,
      "width": 6,
      "height": 5,
      "properties": {
        "title": "Current PRISM Level",
        "view": "singleValue",
        "metrics": [
          [
            "PRISM/D1",
            "PRISMLevel",
            "TeamId", "REPLACE_TEAM_ID",
            {
              "stat": "Maximum",
              "period": 86400,
              "color": "#9C27B0",
              "label": "PRISM Level"
            }
          ]
        ],
        "region": "${AWS::Region}",
        "period": 86400,
        "sparkline": false,
        "setPeriodToTimeRange": false
      }
    },
    {
      "type": "metric",
      "x": 6,
      "y": 1,
      "width": 6,
      "height": 5,
      "properties": {
        "title": "AI ROI Multiplier",
        "view": "singleValue",
        "metrics": [
          [
            "PRISM/D1",
            "AIROIMultiplier",
            "TeamId", "REPLACE_TEAM_ID",
            {
              "stat": "Average",
              "period": 86400,
              "color": "#4CAF50",
              "label": "ROI (x)"
            }
          ]
        ],
        "region": "${AWS::Region}",
        "period": 86400,
        "sparkline": true
      }
    },

    {
      "type": "metric",
      "x": 12,
      "y": 1,
      "width": 3,
      "height": 5,
      "properties": {
        "title": "Deployment Frequency",
        "view": "singleValue",
        "metrics": [
          [
            "PRISM/D1",
            "DeploymentCount",
            "TeamId", "REPLACE_TEAM_ID",
            {
              "stat": "Sum",
              "period": 604800,
              "color": "#2196F3",
              "label": "Deploys/Week"
            }
          ]
        ],
        "region": "${AWS::Region}",
        "period": 604800,
        "sparkline": true
      }
    },
    {
      "type": "metric",
      "x": 15,
      "y": 1,
      "width": 3,
      "height": 5,
      "properties": {
        "title": "Lead Time",
        "view": "singleValue",
        "metrics": [
          [
            "PRISM/D1",
            "LeadTimeSeconds",
            "TeamId", "REPLACE_TEAM_ID",
            {
              "stat": "Average",
              "period": 604800,
              "color": "#1565C0",
              "label": "Avg Seconds"
            }
          ]
        ],
        "region": "${AWS::Region}",
        "period": 604800,
        "sparkline": true
      }
    },
    {
      "type": "metric",
      "x": 18,
      "y": 1,
      "width": 3,
      "height": 5,
      "properties": {
        "title": "Change Failure Rate",
        "view": "singleValue",
        "metrics": [
          [
            "PRISM/D1",
            "ChangeFailureRate",
            "TeamId", "REPLACE_TEAM_ID",
            {
              "stat": "Average",
              "period": 604800,
              "color": "#0D47A1",
              "label": "CFR %"
            }
          ]
        ],
        "region": "${AWS::Region}",
        "period": 604800,
        "sparkline": true
      }
    },
    {
      "type": "metric",
      "x": 21,
      "y": 1,
      "width": 3,
      "height": 5,
      "properties": {
        "title": "MTTR",
        "view": "singleValue",
        "metrics": [
          [
            "PRISM/D1",
            "MTTRSeconds",
            "TeamId", "REPLACE_TEAM_ID",
            {
              "stat": "Average",
              "period": 604800,
              "color": "#1976D2",
              "label": "Avg Seconds"
            }
          ]
        ],
        "region": "${AWS::Region}",
        "period": 604800,
        "sparkline": true
      }
    },

    {
      "type": "metric",
      "x": 0,
      "y": 6,
      "width": 12,
      "height": 6,
      "properties": {
        "title": "AI Adoption Trend (90 Days)",
        "view": "timeSeries",
        "stacked": false,
        "metrics": [
          [
            "PRISM/D1",
            "AIAcceptanceRate",
            "TeamId", "REPLACE_TEAM_ID",
            {
              "stat": "Average",
              "period": 86400,
              "color": "#9C27B0",
              "label": "AI Acceptance %"
            }
          ]
        ],
        "region": "${AWS::Region}",
        "period": 86400,
        "start": "-P90D",
        "yAxis": {
          "left": { "min": 0, "max": 100, "label": "Percent" }
        },
        "annotations": {
          "horizontal": [
            { "value": 30, "color": "#FF9800", "label": "L2 Threshold" },
            { "value": 50, "color": "#4CAF50", "label": "L3 Threshold" },
            { "value": 70, "color": "#2196F3", "label": "L4 Threshold" }
          ]
        }
      }
    },
    {
      "type": "metric",
      "x": 12,
      "y": 6,
      "width": 12,
      "height": 6,
      "properties": {
        "title": "Feature Velocity Trend (90 Days)",
        "view": "timeSeries",
        "stacked": false,
        "metrics": [
          [
            "PRISM/D1",
            "DeploymentCount",
            "TeamId", "REPLACE_TEAM_ID",
            {
              "stat": "Sum",
              "period": 86400,
              "color": "#2196F3",
              "label": "Daily Deploys"
            }
          ]
        ],
        "region": "${AWS::Region}",
        "period": 86400,
        "start": "-P90D",
        "yAxis": {
          "left": { "min": 0, "label": "Deployments" }
        }
      }
    },

    {
      "type": "metric",
      "x": 0,
      "y": 12,
      "width": 12,
      "height": 6,
      "properties": {
        "title": "Eval Quality Trend (90 Days)",
        "view": "timeSeries",
        "stacked": false,
        "metrics": [
          [
            "PRISM/D1",
            "EvalGatePassRate",
            "TeamId", "REPLACE_TEAM_ID",
            {
              "stat": "Average",
              "period": 86400,
              "color": "#AB47BC",
              "label": "Eval Pass Rate %"
            }
          ]
        ],
        "region": "${AWS::Region}",
        "period": 86400,
        "start": "-P90D",
        "yAxis": {
          "left": { "min": 0, "max": 100, "label": "Percent" }
        },
        "annotations": {
          "horizontal": [
            { "value": 80, "color": "#FF9800", "label": "Minimum Target" },
            { "value": 95, "color": "#4CAF50", "label": "L4 Target" }
          ]
        }
      }
    },
    {
      "type": "metric",
      "x": 12,
      "y": 12,
      "width": 12,
      "height": 6,
      "properties": {
        "title": "Team Comparison — AI Acceptance Rate",
        "view": "timeSeries",
        "stacked": false,
        "metrics": [
          [
            "PRISM/D1",
            "AIAcceptanceRate",
            "TeamId", "team-alpha",
            {
              "stat": "Average",
              "period": 86400,
              "color": "#9C27B0",
              "label": "Team Alpha"
            }
          ],
          [
            "PRISM/D1",
            "AIAcceptanceRate",
            "TeamId", "team-bravo",
            {
              "stat": "Average",
              "period": 86400,
              "color": "#E040FB",
              "label": "Team Bravo"
            }
          ],
          [
            "PRISM/D1",
            "AIAcceptanceRate",
            "TeamId", "team-charlie",
            {
              "stat": "Average",
              "period": 86400,
              "color": "#CE93D8",
              "label": "Team Charlie"
            }
          ]
        ],
        "region": "${AWS::Region}",
        "period": 86400,
        "start": "-P90D",
        "yAxis": {
          "left": { "min": 0, "max": 100, "label": "Percent" }
        }
      }
    },

    {
      "type": "metric",
      "x": 0,
      "y": 18,
      "width": 24,
      "height": 6,
      "properties": {
        "title": "Week-over-Week Improvement",
        "view": "timeSeries",
        "stacked": false,
        "metrics": [
          [
            {
              "expression": "100 * (m1 - METRICS('m1', -604800)) / METRICS('m1', -604800)",
              "label": "AI Acceptance WoW %",
              "id": "wow_ai",
              "color": "#9C27B0",
              "period": 604800
            }
          ],
          [
            {
              "expression": "100 * (m2 - METRICS('m2', -604800)) / METRICS('m2', -604800)",
              "label": "Deploys WoW %",
              "id": "wow_df",
              "color": "#2196F3",
              "period": 604800
            }
          ],
          [
            "PRISM/D1",
            "AIAcceptanceRate",
            "TeamId", "REPLACE_TEAM_ID",
            {
              "stat": "Average",
              "period": 604800,
              "id": "m1",
              "visible": false
            }
          ],
          [
            "PRISM/D1",
            "DeploymentCount",
            "TeamId", "REPLACE_TEAM_ID",
            {
              "stat": "Sum",
              "period": 604800,
              "id": "m2",
              "visible": false
            }
          ]
        ],
        "region": "${AWS::Region}",
        "period": 604800,
        "start": "-P90D",
        "yAxis": {
          "left": { "label": "% Change" }
        },
        "annotations": {
          "horizontal": [
            { "value": 0, "color": "#9E9E9E", "label": "Baseline" }
          ]
        }
      }
    }
  ]
}
