{
  "widgets": [
    {
      "type": "text",
      "x": 0,
      "y": 0,
      "width": 24,
      "height": 1,
      "properties": {
        "markdown": "# PRISM D1 Velocity — Team Dashboard\n**DORA Metrics** (top) | **AI-DORA Metrics** (bottom) — All metrics use daily (86400s) periods"
      }
    },

    {
      "type": "metric",
      "x": 0,
      "y": 1,
      "width": 8,
      "height": 6,
      "properties": {
        "title": "Deployment Frequency",
        "view": "bar",
        "stacked": false,
        "metrics": [
          [
            "PRISM/D1",
            "DeploymentCount",
            "TeamId", "REPLACE_TEAM_ID",
            "Repo", "REPLACE_REPO",
            {
              "stat": "Sum",
              "period": 86400,
              "color": "#2196F3",
              "label": "Deploys/Day"
            }
          ]
        ],
        "region": "${AWS::Region}",
        "period": 86400,
        "yAxis": {
          "left": { "min": 0, "label": "Deployments" }
        }
      }
    },
    {
      "type": "metric",
      "x": 8,
      "y": 1,
      "width": 8,
      "height": 6,
      "properties": {
        "title": "Lead Time for Changes",
        "view": "timeSeries",
        "stacked": false,
        "metrics": [
          [
            "PRISM/D1",
            "LeadTimeSeconds",
            "TeamId", "REPLACE_TEAM_ID",
            "Repo", "REPLACE_REPO",
            {
              "stat": "Average",
              "period": 86400,
              "color": "#1565C0",
              "label": "Lead Time (avg)"
            }
          ]
        ],
        "region": "${AWS::Region}",
        "period": 86400,
        "yAxis": {
          "left": { "min": 0, "label": "Seconds" }
        }
      }
    },
    {
      "type": "metric",
      "x": 16,
      "y": 1,
      "width": 8,
      "height": 6,
