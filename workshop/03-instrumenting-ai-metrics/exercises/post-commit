#!/usr/bin/env bash
# PRISM D1 Velocity -- post-commit hook
# Logs commit metadata to a local JSONL file for offline analysis.
# This data is also emitted to EventBridge via the CI workflow.

set -euo pipefail

METRICS_FILE="$(git rev-parse --git-dir)/prism-metrics.jsonl"

# Extract commit details
COMMIT_HASH=$(git rev-parse HEAD)
COMMIT_SHORT=$(git rev-parse --short HEAD)
AUTHOR_EMAIL=$(git log -1 --format='%ae' HEAD)
COMMIT_DATE=$(git log -1 --format='%aI' HEAD)
COMMIT_SUBJECT=$(git log -1 --format='%s' HEAD)

# Extract trailers
AI_ORIGIN=$(git log -1 --format='%(trailers:key=AI-Origin,valueonly)' HEAD | tr -d '[:space:]')
AI_MODEL=$(git log -1 --format='%(trailers:key=AI-Model,valueonly)' HEAD | tr -d '[:space:]')
AI_CONFIDENCE=$(git log -1 --format='%(trailers:key=AI-Confidence,valueonly)' HEAD | tr -d '[:space:]')
AI_SESSION=$(git log -1 --format='%(trailers:key=AI-Session,valueonly)' HEAD | tr -d '[:space:]')
SPEC_REF=$(git log -1 --format='%(trailers:key=Spec,valueonly)' HEAD | tr -d '[:space:]')

# Count changed files and lines
FILES_CHANGED=$(git diff-tree --no-commit-id --name-only -r HEAD | wc -l | tr -d '[:space:]')
LINES_ADDED=$(git diff-tree --no-commit-id --numstat -r HEAD | awk '{sum += $1} END {print sum+0}')
LINES_REMOVED=$(git diff-tree --no-commit-id --numstat -r HEAD | awk '{sum += $2} END {print sum+0}')

# Get repo and branch info
REPO_NAME=$(basename "$(git rev-parse --show-toplevel)")
BRANCH_NAME=$(git rev-parse --abbrev-ref HEAD)

# Build JSON metric record
METRIC_JSON=$(cat <<EOF
{
  "timestamp": "$(date -u +%Y-%m-%dT%H:%M:%SZ)",
  "event_type": "commit",
  "commit_hash": "${COMMIT_HASH}",
  "commit_short": "${COMMIT_SHORT}",
  "author_email": "${AUTHOR_EMAIL}",
  "commit_date": "${COMMIT_DATE}",
  "commit_subject": "${COMMIT_SUBJECT}",
  "repo": "${REPO_NAME}",
  "branch": "${BRANCH_NAME}",
  "ai_origin": "${AI_ORIGIN:-unknown}",
  "ai_model": "${AI_MODEL:-}",
  "ai_confidence": "${AI_CONFIDENCE:-}",
  "ai_session": "${AI_SESSION:-}",
  "spec_ref": "${SPEC_REF:-}",
  "files_changed": ${FILES_CHANGED},
  "lines_added": ${LINES_ADDED},
  "lines_removed": ${LINES_REMOVED}
}
EOF
)

# Compact the JSON to one line and append to metrics file
echo "$METRIC_JSON" | jq -c . >> "$METRICS_FILE" 2>/dev/null || echo "$METRIC_JSON" >> "$METRICS_FILE"

exit 0
