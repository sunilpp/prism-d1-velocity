{
  "agent_name": "prism-task-assistant",
  "description": "Task management agent for the PRISM D1 Velocity workshop. Manages tasks via natural language using Strands SDK with MCP tool discovery.",

  "runtime": {
    "entry_point": "src.task_assistant.agent",
    "factory_function": "create_agent",
    "python_version": "3.11",
    "requirements": "requirements.txt",
    "environment": {
      "TASK_API_URL": "http://localhost:3000",
      "USE_MCP": "true",
      "LOG_LEVEL": "INFO"
    }
  },

  "model": {
    "provider": "bedrock",
    "model_id": "anthropic.claude-sonnet-4-20250514",
    "region": "us-west-2",
    "inference_config": {
      "max_tokens": 4096,
      "temperature": 0.1,
      "top_p": 0.9
    }
  },

  "memory": {
    "enabled": true,
    "provider": "agentcore",
    "session_ttl_seconds": 3600,
    "max_messages_per_session": 100,
    "summary_after_messages": 50
  },

  "gateway": {
    "enabled": true,
    "auth": "iam",
    "throttle_rps": 10,
    "burst_limit": 20,
    "cors_origins": ["https://your-app.example.com"],
    "api_key_required": false
  },

  "observability": {
    "metrics_namespace": "PRISM/D1/Agents",
    "tracing_enabled": true,
    "log_level": "INFO",
    "custom_metrics": [
      {
        "name": "ToolCallCount",
        "unit": "Count",
        "description": "Number of tool calls per invocation"
      },
      {
        "name": "PlannerLatency",
        "unit": "Milliseconds",
        "description": "Time spent in the planner agent"
      },
      {
        "name": "ReviewerPassRate",
        "unit": "Percent",
        "description": "Percentage of reviews that pass"
      }
    ],
    "alarms": [
      {
        "metric": "ErrorRate",
        "threshold": 0.05,
        "period_seconds": 300,
        "evaluation_periods": 3,
        "action": "sns:prism-d1-alerts"
      },
      {
        "metric": "P95Latency",
        "threshold": 30000,
        "period_seconds": 300,
        "evaluation_periods": 2,
        "action": "sns:prism-d1-alerts"
      }
    ]
  },

  "guardrails": {
    "max_steps": 15,
    "timeout_seconds": 60,
    "max_input_tokens": 8192,
    "max_output_tokens": 4096,
    "bedrock_guardrail_id": null,
    "content_filters": {
      "pii_detection": true,
      "profanity_filter": false
    }
  },

  "event_bridge": {
    "enabled": true,
    "event_bus_name": "prism-d1-metrics",
    "detail_type": "prism.d1.agent",
    "source": "prism.d1.velocity"
  },

  "iam": {
    "execution_role_suffix": "agentcore-execution",
    "permissions": [
      {
        "action": "bedrock:InvokeModel",
        "resource": "arn:aws:bedrock:us-west-2::foundation-model/anthropic.claude-sonnet-4-20250514"
      },
      {
        "action": "bedrock:InvokeModel",
        "resource": "arn:aws:bedrock:us-west-2::foundation-model/anthropic.claude-haiku-4-5-20251001"
      },
      {
        "action": "events:PutEvents",
        "resource": "arn:aws:events:us-west-2:*:event-bus/prism-d1-metrics"
      }
    ]
  }
}
