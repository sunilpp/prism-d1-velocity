#!/usr/bin/env bash
# PRISM D1 Velocity -- prepare-commit-msg hook
# Automatically adds AI origin trailers to commit messages.
#
# Detection logic:
#   1. If CLAUDE_CODE_SESSION_ID is set --> AI-Origin: claude-code
#   2. If the commit message already has AI-Origin --> keep it (no override)
#   3. Otherwise --> AI-Origin: human

set -euo pipefail

COMMIT_MSG_FILE="$1"
COMMIT_SOURCE="${2:-}"

# Don't modify merge commits or squash commits
if [ "$COMMIT_SOURCE" = "merge" ] || [ "$COMMIT_SOURCE" = "squash" ]; then
  exit 0
fi

# Read current commit message
COMMIT_MSG=$(cat "$COMMIT_MSG_FILE")

# If AI-Origin trailer already exists, respect it and exit
if echo "$COMMIT_MSG" | grep -q "^AI-Origin:"; then
  exit 0
fi

# Detect AI involvement
AI_ORIGIN="human"
AI_MODEL=""
AI_CONFIDENCE=""
AI_SESSION=""

# Check for Claude Code session
if [ -n "${CLAUDE_CODE_SESSION_ID:-}" ]; then
  AI_ORIGIN="claude-code"
  AI_CONFIDENCE="implementation"
  AI_SESSION="${CLAUDE_CODE_SESSION_ID}"

  # Try to detect the model from Claude Code config
  if command -v claude &> /dev/null; then
    AI_MODEL=$(claude config get model 2>/dev/null || echo "unknown")
  fi
fi

# Ensure there's a blank line before trailers (git convention)
# Check if the message already ends with a blank line
if [ -n "$COMMIT_MSG" ] && [ "$(echo "$COMMIT_MSG" | tail -1)" != "" ]; then
  echo "" >> "$COMMIT_MSG_FILE"
fi

# Append trailers
echo "AI-Origin: ${AI_ORIGIN}" >> "$COMMIT_MSG_FILE"

if [ -n "$AI_MODEL" ]; then
  echo "AI-Model: ${AI_MODEL}" >> "$COMMIT_MSG_FILE"
fi

if [ -n "$AI_CONFIDENCE" ]; then
  echo "AI-Confidence: ${AI_CONFIDENCE}" >> "$COMMIT_MSG_FILE"
fi

if [ -n "$AI_SESSION" ]; then
  echo "AI-Session: ${AI_SESSION}" >> "$COMMIT_MSG_FILE"
fi

exit 0
